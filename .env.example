# AlphaVantage Market Data API Key (Free tier available at alphavantage.co)
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# NextAuth Authentication Secret (Generate a random string)
NEXTAUTH_SECRET=your_super_secret_nextauth_key_here
NEXTAUTH_URL=http://localhost:3000

# MongoDB Database Connection String (Local or MongoDB Atlas URI)
MONGODB_URI=mongodb://localhost:27017/vault_ai_db

# Google Gemini AI Generative API Key (Get from aistudio.google.com)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key
